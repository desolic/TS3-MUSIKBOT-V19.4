# =============================================================================
# .env.example — Build-Argumente für das gehärtete TS3AudioBot-Image
# Kopieren nach .env und mit GEPRÜFTEN Werten füllen (siehe README, Abschnitt Pinning).
# Diese Datei enthält KEINE Geheimnisse (nur Versionen/Checksummen).
# =============================================================================

# --- Base-Image-Digests (per `docker inspect` ermitteln) ---
UBUNTU_DIGEST=REPLACE_WITH_UBUNTU_DIGEST
DOTNET_DIGEST=REPLACE_WITH_DOTNET_DIGEST

# --- TS3AudioBot ---
TSAB_VERSION=0.13.0
TSAB_SHA256=REPLACE_WITH_TS3AUDIOBOT_ZIP_SHA256

# --- yt-dlp (Resolver) ---
YTDLP_VERSION=2025.05.22
YTDLP_SHA256=REPLACE_WITH_YTDLP_LINUX_SHA256

# --- statisches ffmpeg (BtbN, datierter autobuild-Tag pinnen) ---
FFMPEG_TAG=autobuild-2025-05-01-12-30
FFMPEG_SHA256=REPLACE_WITH_FFMPEG_TARBALL_SHA256
